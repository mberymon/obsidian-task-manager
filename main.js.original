          res.writeHead(404, { ...CORS_HEADERS, "Content-Type": "application/json" });
          res.end(JSON.stringify({ error: "MCP server is not enabled" }));
          return;
        }
        res.writeHead(200, {
          "Content-Type": "text/event-stream",
          "Cache-Control": "no-cache",
          "Connection": "keep-alive",
          ...CORS_HEADERS
        });
        const sessionId = Math.random().toString(36).substring(2, 15);
        this.sseSessions.set(sessionId, res);
        res.write(`event: endpoint
data: /mcp?sessionId=${sessionId}

`);
        req.on("close", () => {
          this.sseSessions.delete(sessionId);
        });
        return;
      }
      if (req.method === "POST" && pathname === "/mcp") {
        if (!this.settings.mcpEnabled) {
          res.writeHead(404, { ...CORS_HEADERS, "Content-Type": "application/json" });
          res.end(JSON.stringify({ error: "MCP server is not enabled" }));
          return;
        }
        let body = "";
        req.on("data", (chunk) => {
          body += chunk.toString();
        });
        req.on("end", async () => {
          try {
            const response = await this.mcpHandler.handle(body);
            const sessionId = parsedUrl.searchParams.get("sessionId");
            if (sessionId && this.sseSessions.has(sessionId)) {
              const sseRes = this.sseSessions.get(sessionId);
              sseRes.write(`event: message
data: ${JSON.stringify(response)}

`);
              res.writeHead(200, { ...CORS_HEADERS, "Content-Type": "text/plain" });
              res.end("accepted");
            } else {
              res.writeHead(200, { ...CORS_HEADERS, "Content-Type": "application/json" });
              res.end(JSON.stringify(response));
            }
          } catch (e) {
            res.writeHead(500, { ...CORS_HEADERS, "Content-Type": "application/json" });
            res.end(JSON.stringify({ error: e.message }));
          }
        });
        return;
      }
      res.writeHead(404, { ...CORS_HEADERS, "Content-Type": "application/json" });
      res.end(JSON.stringify({ error: "Not found" }));
    });
    server.on("error", (e) => {
      this.log(`HTTP API server error: ${e.message}`);
    });
    server.listen(this.settings.httpApiPort, "127.0.0.1", () => {
      this.log(`HTTP API server started on ${this.baseUrl}`);
    });
    this.server = server;
  }
  stop() {
    if (!this.server) return;
    try {
      this.server.close();
    } catch (e) {
    }
    this.server = null;
    this.sseSessions.clear();
    this.log("HTTP API server stopped");
  }
  restart() {
    this.stop();
    this.start();
  }
};

