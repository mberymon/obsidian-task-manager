      const lbl = typeRow.createEl("label", { cls: "km-radio-card" + (bg.type === val ? " is-selected" : "") });
      const radio = lbl.createEl("input", { type: "radio", attr: { name: "kanban-bg-type" } });
      radio.value = val;
      radio.checked = bg.type === val;
      lbl.createEl("span", { text: label, cls: "km-radio-label" });
