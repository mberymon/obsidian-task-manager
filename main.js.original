    renderRows();
  }
  createColorDropdown(parentEl, currentColorId, onChange) {
    const wrapper = parentEl.createDiv({ cls: "gcal-color-dropdown-wrapper" });
    const button = wrapper.createEl("button", { cls: "gcal-color-dropdown-btn" });
    button.type = "button";
    const activeColor = GCAL_EVENT_COLORS.find((c) => c.id === currentColorId) || GCAL_EVENT_COLORS[0];
    const dot = button.createDiv({ cls: "gcal-color-dropdown-dot" });
    dot.style.backgroundColor = activeColor.hex;
    const label = button.createSpan({ text: activeColor.name, cls: "gcal-color-dropdown-label" });
    const menu = wrapper.createDiv({ cls: "gcal-color-dropdown-menu" });
    menu.style.display = "none";
    GCAL_EVENT_COLORS.forEach((color) => {
      const item = menu.createDiv({ cls: "gcal-color-dropdown-item" });
      const itemDot = item.createDiv({ cls: "gcal-color-dropdown-dot" });
      itemDot.style.backgroundColor = color.hex;
      item.createSpan({ text: color.name });
      if (color.id === currentColorId) {
        item.addClass("is-selected");
      }
      item.onclick = (e) => {
        e.stopPropagation();
        dot.style.backgroundColor = color.hex;
        label.setText(color.name);
        menu.querySelectorAll(".gcal-color-dropdown-item").forEach((el) => el.removeClass("is-selected"));
        item.addClass("is-selected");
        menu.style.display = "none";
        onChange(color.id);
      };
    });
    button.onclick = (e) => {
      e.stopPropagation();
      const isVisible = menu.style.display === "block";
      document.querySelectorAll(".gcal-color-dropdown-menu").forEach((m) => {
        m.style.display = "none";
      });
      menu.style.display = isVisible ? "none" : "block";
    };
    const safeClickOutside = (e) => {
      if (!document.body.contains(wrapper)) {
        document.removeEventListener("click", safeClickOutside);
        return;
      }
      if (!wrapper.contains(e.target)) {
        menu.style.display = "none";
      }
    };
    document.addEventListener("click", safeClickOutside);
  }
