          if (duplicate) {
            new import_obsidian20.Notice(`Type "${newVal}" already exists.`);
            input.value = typeConfig.name;
            return;
          }
          typeConfig.name = newVal;
          await this.plugin.saveSettings();
          this.refreshCalendarViews();
        };
        const right = row.createDiv({ cls: "task-type-setting-right" });
        this.createColorDropdown(right, typeConfig.colorId, async (newColorId) => {
          typeConfig.colorId = newColorId;
          await this.plugin.saveSettings();
          this.refreshCalendarViews();
        });
        if (typeConfig.name.toLowerCase() !== "task") {
          const deleteBtn = right.createEl("button", { text: "Delete", cls: "mod-warning" });
          deleteBtn.onclick = async () => {
            this.plugin.settings.taskTypes.splice(index, 1);
            await this.plugin.saveSettings();
            renderRows();
            this.refreshCalendarViews();
            new import_obsidian20.Notice("Task type deleted.");
          };
        } else {
          const placeholder = right.createDiv();
          placeholder.style.width = "68px";
        }
      });
