      const labelEl = monthsDiv.createEl("span", { cls: "tasks-heatmap-month-label", text: lbl.text });
      labelEl.style.gridColumnStart = String(lbl.col + 1);
    });
    const bodyDiv = container.createDiv({ cls: "tasks-heatmap-body" });
    const daysDiv = bodyDiv.createDiv({ cls: "tasks-heatmap-days" });
    daysDiv.createEl("span", { text: "" });
    daysDiv.createEl("span", { text: "M" });
    daysDiv.createEl("span", { text: "" });
    daysDiv.createEl("span", { text: "W" });
    daysDiv.createEl("span", { text: "" });
    daysDiv.createEl("span", { text: "F" });
    daysDiv.createEl("span", { text: "" });
    const gridDiv = bodyDiv.createDiv({ cls: "tasks-heatmap-grid" });
    let maxCount = 0;
    for (const count of Object.values(occurrenceDates)) {
      if (count > maxCount) maxCount = count;
    }
    for (let col = 0; col < 53; col++) {
      for (let row = 0; row < 7; row++) {
        const cellDate = new Date(startDate);
        cellDate.setDate(startDate.getDate() + (col * 7 + row));
        const dateStr = toLocalYYYYMMDD(cellDate);
        const cellEl = gridDiv.createDiv({ cls: "tasks-heatmap-cell" });
        if (cellDate > today) {
          cellEl.addClass("future");
        } else {
          const count = occurrenceDates[dateStr] || 0;
          let level = 0;
          if (count > 0) {
            if (maxCount === 1) {
              level = 4;
            } else if (maxCount === 2) {
              level = count === 1 ? 2 : 4;
            } else if (maxCount === 3) {
              level = count === 1 ? 2 : count === 2 ? 3 : 4;
            } else {
              const ratio = count / maxCount;
              if (ratio <= 0.25) level = 1;
              else if (ratio <= 0.5) level = 2;
              else if (ratio <= 0.75) level = 3;
              else level = 4;
            }
          }
          cellEl.addClass(`level-${level}`);
          const formattedDate = cellDate.toLocaleDateString("en-US", {
            weekday: "long",
            year: "numeric",
            month: "long",
            day: "numeric"
          });
          const text = count === 0 ? `No completions on ${formattedDate}` : `${count} completion${count > 1 ? "s" : ""} on ${formattedDate}`;
          cellEl.setAttribute("title", text);
        }
      }
    }
    const sortedDates = Object.keys(occurrenceDates).sort();
    let currentStreak = 0;
    let bestStreak = 0;
    if (sortedDates.length > 0) {
      let tempStreak = 1;
      bestStreak = 1;
      for (let i = 1; i < sortedDates.length; i++) {
        const prevDate = parseLocalDate(sortedDates[i - 1]);
        const currDate = parseLocalDate(sortedDates[i]);
