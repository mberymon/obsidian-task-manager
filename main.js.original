  }
  // ── Helpers ───────────────────────────────────────────────────────────────
  field(parent, label, desc, build) {
    const wrap = parent.createDiv({ cls: "km-field" });
    wrap.createEl("label", { cls: "km-field-label", text: label });
    if (desc) wrap.createEl("p", { cls: "km-field-desc", text: desc });
    const inputWrap = wrap.createDiv({ cls: "km-field-input" });
    build(inputWrap);
  }
  sectionTitle(parent, text) {
    parent.createEl("h4", { cls: "km-section-title", text });
  }
  toggle(parent, label, value, onChange) {
    const row = parent.createDiv({ cls: "km-toggle-row" });
    row.createEl("span", { text: label, cls: "km-toggle-label" });
    const lbl = row.createEl("label", { cls: "km-toggle-switch" });
    const chk = lbl.createEl("input", { type: "checkbox" });
    chk.checked = value;
    chk.onchange = () => onChange(chk.checked);
    lbl.createEl("span", { cls: "km-toggle-thumb" });
  }
};

