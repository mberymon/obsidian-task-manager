          }
        } else if (diff > 1) {
          tempStreak = 1;
        }
      }
      const lastDateStr = sortedDates[sortedDates.length - 1];
      const lastDate = parseLocalDate(lastDateStr);
      const daysSinceLastCompletion = getDaysDiff(lastDate, today);
      if (daysSinceLastCompletion <= 1) {
        currentStreak = tempStreak;
      }
    }
    const footerDiv = container.createDiv({ cls: "tasks-heatmap-footer" });
    if (bestStreak > 0) {
      const streakDiv = footerDiv.createDiv({ cls: "tasks-heatmap-streak" });
      const bestDayText = bestStreak === 1 ? "day" : "days";
      streakDiv.setText(`\u{1F525} ${currentStreak} day streak (best: ${bestStreak} ${bestDayText})`);
    }
    const legendDiv = footerDiv.createDiv({ cls: "tasks-heatmap-legend" });
    legendDiv.createEl("span", { text: "Less" });
    legendDiv.createDiv({ cls: "tasks-heatmap-legend-cell level-0" });
    legendDiv.createDiv({ cls: "tasks-heatmap-legend-cell level-1" });
    legendDiv.createDiv({ cls: "tasks-heatmap-legend-cell level-2" });
    legendDiv.createDiv({ cls: "tasks-heatmap-legend-cell level-3" });
    legendDiv.createDiv({ cls: "tasks-heatmap-legend-cell level-4" });
    legendDiv.createEl("span", { text: "More" });
