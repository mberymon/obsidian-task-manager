    const menu = new import_obsidian17.Menu();
    menu.addItem(
      (item) => item.setTitle("Open Calendar").setIcon("calendar").onClick(() => {
        openCalendarView(plugin);
      })
    );
    menu.addItem(
      (item) => item.setTitle("Open Kanban").setIcon("kanban").onClick(() => {
        plugin.openKanbanView();
      })
    );
    menu.addItem(
      (item) => item.setTitle("Open Table").setIcon("table").onClick(() => {
        plugin.openTableView();
      })
    );
    menu.addItem(
      (item) => item.setTitle("Refresh Calendar Events").setIcon("refresh-cw").onClick(async () => {
        plugin.googleCalClient.invalidateCache();
        const leaves = plugin.app.workspace.getLeavesOfType(CALENDAR_VIEW_TYPE);
