          if (leaf.view && "refresh" in leaf.view) {
            await leaf.view.refresh();
          }
        }
        new import_obsidian17.Notice("Calendar events refreshed");
      })
    );
    menu.addSeparator();
    menu.addItem(
      (item) => item.setTitle("View Activity Log").setIcon("list").onClick(() => {
        plugin.commands.openActivityLog();
      })
    );
    menu.showAtMouseEvent(e);
  });
}
function openCalendarView(plugin) {
