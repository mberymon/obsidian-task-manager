          let newName = `type ${indexName}`;
          while (types.some((t) => t.name.toLowerCase() === newName)) {
            indexName++;
            newName = `type ${indexName}`;
          }
          this.plugin.settings.taskTypes.push({
            name: newName,
            colorId: defaultColorId
