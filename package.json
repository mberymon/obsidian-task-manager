{
  "name": "obsidian-task-manager",
  "version": "1.2.0",
  "description": "Local task management with markdown files and Google Calendar integration.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "task-manager",
    "plugin"
  ],
  "author": "Antone Heyward",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "latest",
    "tslib": "^2.8.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "rrule": "^2.8.1"
  }
}